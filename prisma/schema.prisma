generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String              @id @default(cuid())
  name              String
  email             String              @unique
  passwordHash      String
  role              Role                @default(VIEWER)
  department        Department          @default(SALES)
  isActive          Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  deletedAt         DateTime?
  activityLogs      ActivityLog[]
  assignedCustomers Customer[]          @relation("CustomerOwner")
  inspections       InspectionRequest[] @relation("InspectionAssignee")
  interactions      Interaction[]
  quotations        Quotation[]
  notifications     Notification[]
}

model Customer {
  id           String              @id @default(cuid())
  name         String
  phone        String
  altPhone     String?
  type         CustomerType        @default(INDIVIDUAL)
  source       CustomerSource      @default(VISIT)
  address      String?
  notes        String?
  stage        PipelineStage       @default(NEW)
  rejectReason String?
  isRepeat     Boolean             @default(false)
  ownerId      String?
  coveredById  String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  deletedAt    DateTime?
  owner        User?               @relation("CustomerOwner", fields: [ownerId], references: [id])
  inspections  InspectionRequest[]
  interactions Interaction[]
  quotations   Quotation[]

  @@index([ownerId])
  @@index([stage])
  @@index([phone])
}

model Interaction {
  id         String          @id @default(cuid())
  customerId String
  userId     String
  type       InteractionType @default(NOTE)
  note       String
  createdAt  DateTime        @default(now())
  customer   Customer        @relation(fields: [customerId], references: [id])
  user       User            @relation(fields: [userId], references: [id])

  @@index([customerId])
}

model Quotation {
  id                  String          @id @default(cuid())
  number              String          @unique
  customerId          String
  createdById         String
  status              QuotationStatus @default(DRAFT)
  subtotal            Decimal         @default(0) @db.Decimal(12, 2)
  discountPct         Decimal         @default(0) @db.Decimal(5, 2)
  cashbackPct         Decimal         @default(0) @db.Decimal(5, 2)
  discountAmount      Decimal         @default(0) @db.Decimal(12, 2)
  taxPct              Decimal         @default(14) @db.Decimal(5, 2)
  taxAmount           Decimal         @default(0) @db.Decimal(12, 2)
  total               Decimal         @default(0) @db.Decimal(12, 2)
  needsApproval       Boolean         @default(false)
  approvedById        String?
  validUntil          DateTime
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  deletedAt           DateTime?
  previousQuotationId String?
  quotationType       QuotationType   @default(INITIAL)
  reviewNote          String?
  reviewStatus        ReviewStatus    @default(PENDING_REVIEW)
  reviewedAt          DateTime?
  reviewedById        String?
  createdBy           User            @relation(fields: [createdById], references: [id])
  customer            Customer        @relation(fields: [customerId], references: [id])
  items               QuotationItem[]

  @@index([customerId])
  @@index([status])
}

model QuotationItem {
  id          String    @id @default(cuid())
  quotationId String
  description String
  quantity    Decimal   @default(1) @db.Decimal(10, 2)
  unitPrice   Decimal   @default(0) @db.Decimal(12, 2)
  lineTotal   Decimal   @default(0) @db.Decimal(12, 2)
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId])
}

model DiscountRequest {
  id            String                @id @default(cuid())
  quotationId   String
  requestedPct  Decimal               @db.Decimal(5, 2)
  approvedPct   Decimal?              @db.Decimal(5, 2)
  status        DiscountRequestStatus @default(PENDING)
  requestedById String
  decidedById   String?
  reason        String?
  createdAt     DateTime              @default(now())
  decidedAt     DateTime?

  @@index([quotationId])
  @@index([status])
}

model InspectionRequest {
  id          String             @id @default(cuid())
  customerId  String
  location    InspectionLocation @default(INSIDE_CAIRO)
  address     String
  phone       String
  notes       String?
  status      InspectionStatus   @default(REQUESTED)
  scheduledAt DateTime?
  dueDate     DateTime
  assigneeId  String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  deletedAt   DateTime?
  type        InspectionType     @default(PRICING)
  assignee    User?              @relation("InspectionAssignee", fields: [assigneeId], references: [id])
  customer    Customer           @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([status])
  @@index([dueDate])
}

model Attachment {
  id        String           @id @default(cuid())
  parent    AttachmentParent
  parentId  String
  fileName  String
  filePath  String
  mimeType  String?
  createdAt DateTime         @default(now())

  @@index([parent, parentId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String
  details   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([userId])
}

model Notification {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  title      String
  body       String
  type       String
  entityId   String?
  entityType String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([userId, isRead])
}

model SystemSettings {
  id                 String    @id @default("singleton")
  discountBasePct    Decimal   @default(18) @db.Decimal(5, 2)
  discountMaxReqPct  Decimal   @default(25) @db.Decimal(5, 2)
  vatPct             Decimal   @default(14) @db.Decimal(5, 2)
  quotationValidDays Int       @default(3)
  cashbackActive     Boolean   @default(true)
  cashbackStartDate  DateTime?
  companyLogoUrl     String?
  companyName        String?
  updatedById        String?
  updatedAt          DateTime  @updatedAt
}

model CashbackTier {
  id        String  @id @default(cuid())
  orderFrom Int
  orderTo   Int?
  pct       Decimal @db.Decimal(5, 2)
  isActive  Boolean @default(true)
}

model Referral {
  id             String         @id @default(cuid())
  referrerId     String
  newCustomerId  String
  newQuotationId String
  referralOrder  Int
  cashbackPct    Decimal        @db.Decimal(5, 2)
  baseAmount     Decimal        @db.Decimal(12, 2)
  cashbackAmount Decimal        @db.Decimal(12, 2)
  status         CashbackStatus @default(PENDING)
  createdAt      DateTime       @default(now())
  paidAt         DateTime?

  @@index([referrerId])
  @@index([status])
}

model PriceListItem {
  id          String   @id @default(cuid())
  category    String
  spec        String
  unit        String
  price       Decimal  @db.Decimal(12, 2)
  isActive    Boolean  @default(true)
  updatedById String?
  updatedAt   DateTime @updatedAt
}

model ProductRecipe {
  id            String      @id @default(cuid())
  productTypeId String
  materialId    String?
  qtyRule       QtyRule
  defaultQty    Decimal?    @db.Decimal(10, 2)
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime
  customFactor  Decimal?    @db.Decimal(4, 2)
  factorMode    FactorMode  @default(STANDARD)
  Material      Material?   @relation(fields: [materialId], references: [id])
  ProductType   ProductType @relation(fields: [productTypeId], references: [id])

  @@index([productTypeId])
}

model ConfigType {
  id             String      @id
  productTypeId  String
  nameAr         String
  code           String
  sectionMod     Decimal     @db.Decimal(4, 2)
  anglesCount    Int
  openCloseCount Int
  createdAt      DateTime    @default(now())
  updatedAt      DateTime
  ProductType    ProductType @relation(fields: [productTypeId], references: [id])

  @@index([productTypeId])
}

model ManualItem {
  id        String   @id
  code      String   @unique
  nameAr    String
  cost      Decimal  @db.Decimal(12, 2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model Material {
  id            String           @id
  code          String           @unique
  nameAr        String
  category      MaterialCategory
  cost          Decimal          @db.Decimal(12, 2)
  unit          MaterialUnit
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime
  ProductRecipe ProductRecipe[]
}

model PricingFactor {
  id        String   @id
  value     Decimal  @db.Decimal(4, 2)
  label     String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model ProductType {
  id            String          @id
  nameAr        String
  code          String          @unique
  calcStrategy  CalcStrategy
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime
  ConfigType    ConfigType[]
  ProductRecipe ProductRecipe[]
}

enum Role {
  ADMIN
  SALES_MANAGER
  SALES_REP
  INSPECTION_MANAGER
  VIEWER
  REVIEW
}

enum Department {
  EXECUTIVE
  SALES
  INSPECTIONS
  TECHNICAL_OFFICE
  PROJECTS
}

enum CustomerType {
  INDIVIDUAL
  ENGINEER
  COMPANY
}

enum CustomerSource {
  AD
  REFERRAL
  WHATSAPP
  EXHIBITION
  VISIT
}

enum PipelineStage {
  NEW
  PRICED
  FOLLOW_UP
  INSPECTION
  EXECUTION
  RE_INSPECTION_FOLLOWUP
  REJECTED
}

enum InteractionType {
  CALL
  WHATSAPP
  VISIT
  NOTE
}

enum QuotationStatus {
  DRAFT
  SENT
  PENDING_APPROVAL
  APPROVED
  EXPIRED
}

enum InspectionStatus {
  REQUESTED
  SCHEDULED
  DONE
  OVERDUE
}

enum InspectionLocation {
  INSIDE_CAIRO
  OUTSIDE_CAIRO
}

enum InspectionType {
  PRICING
  EXECUTION
}

enum AttachmentParent {
  CUSTOMER
  QUOTATION
  INSPECTION
}

enum ReviewStatus {
  PENDING_REVIEW
  APPROVED
  RETURNED
}

enum QuotationType {
  INITIAL
  FINAL
}

enum DiscountRequestStatus {
  PENDING
  APPROVED
  REJECTED
  ADJUSTED
}

enum CashbackStatus {
  PENDING
  ELIGIBLE
  PAID
  CANCELLED
}

enum FactorMode {
  STANDARD
  FIXED_AFTER
  CUSTOM_FACTOR
}

enum CalcStrategy {
  SHOWER
  RECIPE_FIXED
}

enum MaterialCategory {
  GLASS
  GLASS_ADDON_AREA
  CHAMFER
  SECTION
  DOOR_SET
  MACHINE
  HANDLE
  OPEN_CLOSE
  ACCESSORY
  TENSION
  ELBOW
  CEILING_STRIP
  LATCH
  SPIDER
  OTHER
}

enum MaterialUnit {
  SQM
  LINEAR_M
  PIECE
  SET
}

enum QtyRule {
  FIXED
  BY_AREA
  BY_LENGTH
  BY_CONFIG
  MANUAL
}
