generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String                  @id @default(cuid())
  name                     String
  email                    String                  @unique
  passwordHash             String
  role                     Role                    @default(VIEWER)
  department               Department              @default(SALES)
  isActive                 Boolean                 @default(true)
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  deletedAt                DateTime?

  // ── SCR-016: قفل الحساب (5 محاولات فاشلة / rolling 24h → قفل 24h) ──
  failedLoginAttempts      Int                     @default(0)
  lastFailedLoginAt        DateTime?
  lockedUntil              DateTime?

  activityLogs             ActivityLog[]
  assignedCustomers        Customer[]              @relation("CustomerOwner")
  inspections              InspectionRequest[]     @relation("InspectionAssignee")
  interactions             Interaction[]
  quotations               Quotation[]
  notifications            Notification[]
  installationOrders       InstallationOrder[]     @relation("InstallationTeamLead")
  payments                 Payment[]
  employee                 Employee?
  managedProjects          Project[]               @relation("ProjectManager")
  approvalRequests         QuotationApproval[]     @relation("ApprovalRequester")
  approvalReviews          QuotationApproval[]     @relation("ApprovalReviewer")
  measurements             InspectionMeasurement[] @relation("MeasurementRecorder")
  uploadedPhotos           InspectionPhoto[]       @relation("PhotoUploader")
  uploadedDocuments        Document[]
  contracts                Contract[]
  tecJobsAsEngineer        QuotationRequest[]      @relation("TecEngineer")
  tecJobsAsSalesOwner      QuotationRequest[]      @relation("TecSalesOwner")
  tecJobsAsInspectionOwner QuotationRequest[]      @relation("TecInspectionOwner")
  uploadedDrawings         Drawing[]               @relation("DrawingUploader")
  approvedDrawings         Drawing[]               @relation("DrawingApprover")
  createdExtraItems        ExtraItem[]             @relation("ExtraItemCreator")
  postInstallReviews       PostInstallReview[]     @relation("PostInstallReviewCreator")
  issuedStatements         ProgressStatement[]     @relation("StatementIssuer")
  issuedInvoices           Invoice[]               @relation("InvoiceIssuer")
  installationPhotos       InstallationPhoto[]     @relation("InstallationPhotoUploader")
  installationItems        InstallationItem[]      @relation("InstallationItemCreator")
}

model Customer {
  id                 String              @id @default(cuid())
  name               String
  phone              String
  altPhone           String?
  type               CustomerType        @default(INDIVIDUAL)
  source             CustomerSource      @default(VISIT)
  address            String?
  notes              String?
  stage              PipelineStage       @default(NEW)
  rejectReason       String?
  isRepeat           Boolean             @default(false)
  isVip              Boolean             @default(false)
  ownerId            String?
  coveredById        String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?
  owner              User?               @relation("CustomerOwner", fields: [ownerId], references: [id])
  inspections        InspectionRequest[]
  interactions       Interaction[]
  quotations         Quotation[]
  projects           Project[]
  contracts          Contract[]
  quotationRequests  QuotationRequest[]
  postInstallReviews PostInstallReview[]
  invoices           Invoice[]

  @@index([ownerId])
  @@index([stage])
  @@index([phone])
}

model PostInstallReview {
  id          String            @id @default(cuid())
  customerId  String
  contractId  String?
  rating      Int
  notes       String?
  issues      String?
  status      PostInstallStatus @default(PENDING)
  createdById String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  customer  Customer  @relation(fields: [customerId], references: [id])
  createdBy User      @relation("PostInstallReviewCreator", fields: [createdById], references: [id])
  contract  Contract? @relation(fields: [contractId], references: [id])

  @@index([customerId])
  @@index([status])
  @@map("post_install_reviews")
}

enum PostInstallStatus {
  PENDING
  CONTACTED
  RESOLVED
  CLOSED
}

model Interaction {
  id         String          @id @default(cuid())
  customerId String
  userId     String
  type       InteractionType @default(NOTE)
  note       String
  createdAt  DateTime        @default(now())
  customer   Customer        @relation(fields: [customerId], references: [id])
  user       User            @relation(fields: [userId], references: [id])

  @@index([customerId])
}

model Quotation {
  id                  String              @id @default(cuid())
  number              String              @unique
  customerId          String
  createdById         String
  status              QuotationStatus     @default(DRAFT)
  subtotal            Decimal             @default(0) @db.Decimal(12, 2)
  discountPct         Decimal             @default(0) @db.Decimal(5, 2)
  cashbackPct         Decimal             @default(0) @db.Decimal(5, 2)
  discountAmount      Decimal             @default(0) @db.Decimal(12, 2)
  taxPct              Decimal             @default(14) @db.Decimal(5, 2)
  taxAmount           Decimal             @default(0) @db.Decimal(12, 2)
  total               Decimal             @default(0) @db.Decimal(12, 2)
  needsApproval       Boolean             @default(false)
  approvedById        String?
  validUntil          DateTime
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  deletedAt           DateTime?
  previousQuotationId String?
  quotationType       QuotationType       @default(INITIAL)
  reviewNote          String?
  reviewStatus        ReviewStatus        @default(PENDING_REVIEW)
  reviewedAt          DateTime?
  reviewedById        String?
  createdBy           User                @relation(fields: [createdById], references: [id])
  customer            Customer            @relation(fields: [customerId], references: [id])
  items               QuotationItem[]
  manufacturingOrders ManufacturingOrder[]
  payments            Payment[]
  projectId           String?
  project             Project?            @relation(fields: [projectId], references: [id])
  approval            QuotationApproval?
  contract            Contract?
  quotationRequest    QuotationRequest?
  invoices            Invoice[]

  @@index([customerId])
  @@index([status])
}

model QuotationItem {
  id          String    @id @default(cuid())
  quotationId String
  description String
  quantity    Decimal   @default(1) @db.Decimal(10, 2)
  unitPrice   Decimal   @default(0) @db.Decimal(12, 2)
  lineTotal   Decimal   @default(0) @db.Decimal(12, 2)
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId])
}

model DiscountRequest {
  id            String                @id @default(cuid())
  quotationId   String
  requestedPct  Decimal               @db.Decimal(5, 2)
  approvedPct   Decimal?              @db.Decimal(5, 2)
  status        DiscountRequestStatus @default(PENDING)
  requestedById String
  decidedById   String?
  reason        String?
  createdAt     DateTime              @default(now())
  decidedAt     DateTime?

  @@index([quotationId])
  @@index([status])
}

model InspectionRequest {
  id               String                  @id @default(cuid())
  customerId       String
  location         InspectionLocation      @default(INSIDE_CAIRO)
  address          String
  phone            String
  notes            String?
  status           InspectionStatus        @default(REQUESTED)
  scheduledAt      DateTime?
  dueDate          DateTime
  assigneeId       String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  deletedAt        DateTime?
  type             InspectionType          @default(PRICING)
  siteReadiness    Boolean? // null=لم يُحدَّد، true=جاهز، false=غير جاهز
  assignee         User?                   @relation("InspectionAssignee", fields: [assigneeId], references: [id])
  customer         Customer                @relation(fields: [customerId], references: [id])
  measurements     InspectionMeasurement[]
  photos           InspectionPhoto[]
  quotationRequest QuotationRequest?

  @@index([customerId])
  @@index([status])
  @@index([dueDate])
}

model Attachment {
  id        String           @id @default(cuid())
  parent    AttachmentParent
  parentId  String
  fileName  String
  filePath  String
  mimeType  String?
  createdAt DateTime         @default(now())

  @@index([parent, parentId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String
  details   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([userId])
}

model Notification {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  title      String
  body       String
  type       String
  entityId   String?
  entityType String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([userId, isRead])
}

model ManufacturingOrder {
  id                String             @id @default(cuid())
  // كان @unique — رُفع القيد لتمكين أوامر بديلة (W-06) لنفس العرض؛
  // "أمر أصلي واحد لكل عرض" يُفرض منطقيًا في createManufacturingOrder (parentOrderId: null)
  quotationId       String
  quotation         Quotation          @relation(fields: [quotationId], references: [id])
  status            MfgStatus          @default(PENDING)
  assignedTo        String?
  notes             String?
  expectedAt        DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  installationOrder InstallationOrder?
  extraItems        ExtraItem[]

  // ── SCR-013: أمر التصنيع البديل (W-06) ──
  parentOrderId String?
  faultType     FaultType?
  parentOrder   ManufacturingOrder?  @relation("MfgReplacement", fields: [parentOrderId], references: [id], onDelete: SetNull)
  replacements  ManufacturingOrder[] @relation("MfgReplacement")

  // ── دفعة أ: ربط المصنع (PRC-R04) + سبب الرفض في بوابة المراجعة (PRC-R03) ──
  factoryId       String?
  factory         Factory? @relation(fields: [factoryId], references: [id], onDelete: SetNull)
  rejectionReason String?  @db.Text

  @@index([status])
  @@index([parentOrderId])
  @@index([factoryId])
  @@index([quotationId])
}

// ── دفعة أ: المصانع (PRC-R04) — بسيط عمدًا؛ التقييم/الإحصاءات مؤجّلة بعد UAT ──
model Factory {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique // تكويد شكري — فريد
  contact   String?          // تليفون/إيميل حر
  isActive  Boolean  @default(true)
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  manufacturingOrders ManufacturingOrder[]

  @@map("factories")
}

enum FaultType {
  BREAKAGE
  FACTORY_ERROR
  TEC_ERROR
  MEASUREMENT_ERROR
  CUSTOMER_DELAY
}

model InstallationOrder {
  id                   String             @id @default(cuid())
  manufacturingOrderId String             @unique
  manufacturingOrder   ManufacturingOrder @relation(fields: [manufacturingOrderId], references: [id])
  teamLeadId           String?
  teamLead             User?              @relation("InstallationTeamLead", fields: [teamLeadId], references: [id])
  scheduledAt          DateTime?
  status               InstStatus         @default(PENDING)
  notes                String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  photos InstallationPhoto[]
  items  InstallationItem[]

  @@index([status])
  @@index([teamLeadId])
}

// ── دفعة ج: صور التركيب (IMT-R06) — اختيارية، تموت مع الأمر ──
model InstallationPhoto {
  id                  String            @id @default(cuid())
  installationOrderId String
  installationOrder   InstallationOrder @relation(fields: [installationOrderId], references: [id], onDelete: Cascade)
  url                 String            @db.VarChar(1000)
  caption             String?           @db.VarChar(300)
  uploadedById        String?
  uploadedBy          User?             @relation("InstallationPhotoUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt           DateTime          @default(now())

  @@index([installationOrderId])
  @@map("installation_photos")
}

// ── دفعة ج: بنود التركيب (IMT-R05) — حوادث يسجلها قائد الفريق؛ تغذّي W-06 ──
model InstallationItem {
  id                  String               @id @default(cuid())
  installationOrderId String
  installationOrder   InstallationOrder    @relation(fields: [installationOrderId], references: [id], onDelete: Restrict)
  type                InstallationItemType
  description         String?              @db.VarChar(500)
  quantity            Decimal?             @db.Decimal(10, 2)
  cost                Decimal?             @db.Decimal(12, 2) // اختيارية — حسب الحالة (إجابة إسلام)
  createdById         String
  createdBy           User                 @relation("InstallationItemCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt           DateTime             @default(now())

  @@index([installationOrderId])
  @@index([type])
  @@map("installation_items")
}

enum InstallationItemType {
  BREAKAGE_REPLACEMENT
  MFG_ERROR
  TEC_ERROR
  MEASUREMENT_ERROR
  CLIENT_DELAY
  OTHER
}

model Payment {
  id          String    @id @default(cuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id])
  amount      Decimal   @db.Decimal(12, 2)
  paidAt      DateTime
  method      String
  notes       String?
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())

  // ── SCR-014: ربط اختياري بالبند المخطّط (الدفعة الفعلية مقابل أي بند) ──
  milestoneId String?
  milestone   PaymentMilestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)

  @@index([quotationId])
  @@index([milestoneId])
}

model Employee {
  id            String         @id @default(cuid())
  userId        String?        @unique
  user          User?          @relation(fields: [userId], references: [id])
  nameAr        String
  department    Department
  position      String
  hireDate      DateTime
  salary        Decimal?       @db.Decimal(12, 2)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  leaveRequests LeaveRequest[]
}

model LeaveRequest {
  id         String      @id @default(cuid())
  employeeId String
  employee   Employee    @relation(fields: [employeeId], references: [id])
  type       String
  startDate  DateTime
  endDate    DateTime
  status     LeaveStatus @default(PENDING)
  notes      String?
  createdAt  DateTime    @default(now())

  @@index([employeeId])
  @@index([status])
}

model Project {
  id         String        @id @default(cuid())
  nameAr     String
  customerId String
  customer   Customer      @relation(fields: [customerId], references: [id])
  managerId  String?
  manager    User?         @relation("ProjectManager", fields: [managerId], references: [id])
  status     ProjectStatus @default(ACTIVE)
  startDate  DateTime?
  endDate    DateTime?
  notes      String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  quotations Quotation[]

  @@index([customerId])
  @@index([status])
}

model SystemSettings {
  id                 String    @id @default("singleton")
  discountBasePct    Decimal   @default(18) @db.Decimal(5, 2)
  discountMaxReqPct  Decimal   @default(25) @db.Decimal(5, 2)
  factorMinimum      Decimal   @default(1.5) @db.Decimal(4, 2)
  vatPct             Decimal   @default(14) @db.Decimal(5, 2)
  quotationValidDays Int       @default(3)
  cashbackActive     Boolean   @default(true)
  cashbackStartDate  DateTime?
  companyLogoUrl     String?
  companyName        String?
  updatedById        String?
  updatedAt          DateTime  @updatedAt

  // ── SCR-013: سياسة الخصم الهرمي (P-04) — يملؤها عمرو ──
  managerApprovalCeilingPct   Decimal?  @db.Decimal(5, 2)
  // ── SCR-013: عتبة اعتماد CEO للرسومات (W-05 · Gate3) ──
  ceoDrawingApprovalThreshold Decimal?  @db.Decimal(14, 2)
  // ── SCR-013: تأخير استطلاع الرضا (W-07) ──
  satisfactionSurveyDelayDays Int       @default(3)
  // ── SCR-013: موضع بوابة REVIEW في سلسلة الاعتماد (R-05) — معلّق التوضيح ──
  reviewGatePosition          Int?

  // ── SCR-014: نصوص الضمان الحرة (P-03) — يعدّلها ADMIN من الإعدادات ──
  warrantyTextProjects        String?  @db.Text
  warrantyTextSocialMedia     String?  @db.Text
  // ── SCR-014: تحكّم في مكان ظهور كل ضمان (السوشيال بلا عقد → لا خيار "في العقد" لها) ──
  warrantyProjectsOnQuotation Boolean  @default(true)
  warrantyProjectsOnContract  Boolean  @default(true)
  warrantySocialOnQuotation   Boolean  @default(true)
}

model CashbackTier {
  id        String  @id @default(cuid())
  orderFrom Int
  orderTo   Int?
  pct       Decimal @db.Decimal(5, 2)
  isActive  Boolean @default(true)
}

model Referral {
  id             String         @id @default(cuid())
  referrerId     String
  newCustomerId  String
  newQuotationId String
  referralOrder  Int
  cashbackPct    Decimal        @db.Decimal(5, 2)
  baseAmount     Decimal        @db.Decimal(12, 2)
  cashbackAmount Decimal        @db.Decimal(12, 2)
  status         CashbackStatus @default(PENDING)
  createdAt      DateTime       @default(now())
  paidAt         DateTime?

  @@index([referrerId])
  @@index([status])
}

model PriceListItem {
  id          String   @id @default(cuid())
  category    String
  spec        String
  unit        String
  price       Decimal  @db.Decimal(12, 2)
  isActive    Boolean  @default(true)
  updatedById String?
  updatedAt   DateTime @updatedAt
}

model ProductRecipe {
  id            String      @id @default(cuid())
  productTypeId String
  materialId    String?
  qtyRule       QtyRule
  defaultQty    Decimal?    @db.Decimal(10, 2)
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime
  customFactor  Decimal?    @db.Decimal(4, 2)
  factorMode    FactorMode  @default(STANDARD)
  Material      Material?   @relation(fields: [materialId], references: [id])
  ProductType   ProductType @relation(fields: [productTypeId], references: [id])

  @@index([productTypeId])
}

model ConfigType {
  id             String      @id
  productTypeId  String
  nameAr         String
  code           String
  sectionMod     Decimal     @db.Decimal(4, 2)
  anglesCount    Int
  openCloseCount Int
  createdAt      DateTime    @default(now())
  updatedAt      DateTime
  ProductType    ProductType @relation(fields: [productTypeId], references: [id])

  @@index([productTypeId])
}

model ManualItem {
  id        String   @id
  code      String   @unique
  nameAr    String
  cost      Decimal  @db.Decimal(12, 2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model Material {
  id            String           @id
  code          String           @unique
  nameAr        String
  category      MaterialCategory
  cost          Decimal          @db.Decimal(12, 2)
  unit          MaterialUnit
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime
  ProductRecipe ProductRecipe[]
}

model PricingFactor {
  id        String   @id
  value     Decimal  @db.Decimal(4, 2)
  label     String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model ProductType {
  id            String          @id
  nameAr        String
  code          String          @unique
  calcStrategy  CalcStrategy
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime
  ConfigType    ConfigType[]
  ProductRecipe ProductRecipe[]
}

enum Role {
  ADMIN
  SALES_MANAGER
  SALES_REP
  INSPECTION_MANAGER
  INSPECTION_REP
  VIEWER
  REVIEW
  PROCUREMENT
  INSTALLATIONS
  ACCOUNTING
  HR
  PROJECTS
  TECHNICAL_OFFICE
  TEC_APPROVER
}

enum Department {
  EXECUTIVE
  SALES
  INSPECTIONS
  TECHNICAL_OFFICE
  PROJECTS
  PROCUREMENT
  INSTALLATIONS
  ACCOUNTING
  HR
}

enum CustomerType {
  INDIVIDUAL
  ENGINEER
  COMPANY
}

enum CustomerSource {
  AD
  REFERRAL
  WHATSAPP
  EXHIBITION
  VISIT
}

enum PipelineStage {
  NEW
  PRICED
  FOLLOW_UP
  INSPECTION
  CONTRACT
  EXECUTION
  RE_INSPECTION_FOLLOWUP
  REJECTED
}

enum InteractionType {
  CALL
  WHATSAPP
  VISIT
  NOTE
}

enum QuotationStatus {
  DRAFT
  SENT
  PENDING_APPROVAL
  APPROVED
  EXPIRED
}

enum InspectionStatus {
  REQUESTED
  SCHEDULED
  DONE
  OVERDUE
}

enum InspectionLocation {
  INSIDE_CAIRO
  OUTSIDE_CAIRO
}

enum InspectionType {
  PRICING
  EXECUTION
}

enum AttachmentParent {
  CUSTOMER
  QUOTATION
  INSPECTION
}

enum ReviewStatus {
  PENDING_REVIEW
  APPROVED
  RETURNED
}

enum QuotationType {
  INITIAL
  FINAL
}

enum MfgStatus {
  PENDING
  UNDER_REVIEW
  REJECTED
  IN_PRODUCTION
  READY
  DELIVERED
}

enum InstStatus {
  PENDING
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum DiscountRequestStatus {
  PENDING
  APPROVED
  REJECTED
  ADJUSTED
}

enum CashbackStatus {
  PENDING
  ELIGIBLE
  PAID
  CANCELLED
}

enum FactorMode {
  STANDARD
  FIXED_AFTER
  CUSTOM_FACTOR
}

enum CalcStrategy {
  SHOWER
  RECIPE_FIXED
}

enum MaterialCategory {
  GLASS
  GLASS_ADDON_AREA
  CHAMFER
  SECTION
  DOOR_SET
  MACHINE
  HANDLE
  OPEN_CLOSE
  ACCESSORY
  TENSION
  ELBOW
  CEILING_STRIP
  LATCH
  SPIDER
  OTHER
}

enum MaterialUnit {
  SQM
  LINEAR_M
  PIECE
  SET
}

enum QtyRule {
  FIXED
  BY_AREA
  BY_LENGTH
  BY_CONFIG
  MANUAL
}

model QuotationApproval {
  id            String    @id @default(cuid())
  quotationId   String    @unique
  quotation     Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  requestedById String
  requestedBy   User      @relation("ApprovalRequester", fields: [requestedById], references: [id])
  reviewedById  String?
  reviewedBy    User?     @relation("ApprovalReviewer", fields: [reviewedById], references: [id])
  factor        Decimal   @db.Decimal(10, 4)
  reason        String?
  decision      String?
  rejectionNote String?
  createdAt     DateTime  @default(now())
  decidedAt     DateTime?

  @@index([quotationId])
  @@map("quotation_approvals")
}

model InspectionMeasurement {
  id           String            @id @default(cuid())
  inspectionId String
  inspection   InspectionRequest @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  label        String            @db.VarChar(200)
  value        Decimal           @db.Decimal(12, 4)
  unit         String            @db.VarChar(50)
  minSpec      Decimal?          @db.Decimal(12, 4)
  maxSpec      Decimal?          @db.Decimal(12, 4)
  result       String            @default("PENDING")
  notes        String?           @db.Text
  recordedById String
  recordedBy   User              @relation("MeasurementRecorder", fields: [recordedById], references: [id])
  recordedAt   DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([inspectionId])
  @@map("inspection_measurements")
}

model Document {
  id           String   @id @default(cuid())
  entityType   String   @db.VarChar(50)
  entityId     String
  filename     String   @db.VarChar(300)
  originalName String   @db.VarChar(300)
  mimeType     String   @db.VarChar(100)
  sizeBytes    Int
  url          String   @db.VarChar(1000)
  label        String?  @db.VarChar(200)
  uploadedById String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())

  @@index([entityType, entityId])
  @@map("documents")
}

model Contract {
  id          String    @id @default(cuid())
  customerId  String
  quotationId String    @unique
  signedAt    DateTime?
  notes       String?   @db.Text
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // ── SCR-014: قيمة العقد المجمّدة (snapshot من Quotation.total وقت الإنشاء — النِسب تُحسب منها) ──
  totalValue Decimal? @db.Decimal(14, 2)

  customer           Customer            @relation(fields: [customerId], references: [id])
  quotation          Quotation           @relation(fields: [quotationId], references: [id])
  createdBy          User                @relation(fields: [createdById], references: [id])
  postInstallReviews PostInstallReview[]
  paymentMilestones  PaymentMilestone[]
  progressStatements ProgressStatement[]
  invoices           Invoice[]

  @@index([customerId])
  @@map("contracts")
}

// ── SCR-014: خطة الدفعات المخطّطة — "خطة + فعلي" (النسبة هنا، لا في Payment) ──
model PaymentMilestone {
  id            String   @id @default(cuid())
  contractId    String
  contract      Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  label         String
  percentage    Decimal  @db.Decimal(5, 2)
  plannedAmount Decimal  @db.Decimal(14, 2)
  sortOrder     Int      @default(0)

  payments           Payment[]
  progressStatements ProgressStatement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contractId])
  @@map("payment_milestones")
}

// ── SCR-015 دفعة 1: المستخلص — سند مرقّم (صيغة نصية مركّبة) بـ snapshot مجمّد ──
model ProgressStatement {
  id             String            @id @default(cuid())
  // يُولّد عند ISSUED فقط عبر src/lib/finance/document-number.ts — nullable في DRAFT
  // مشروعات: EG{seq}/YY/M/D · سوشيال: C3_{seq} — تعديل الصيغة = الدالة فقط، بلا migration
  documentNumber String?
  contractId     String
  contract       Contract          @relation(fields: [contractId], references: [id], onDelete: Restrict)
  progressPct    Decimal           @db.Decimal(5, 2)
  // snapshot: يُجمّد وقت الإصدار — لا يُقرأ لايف بعد ISSUED (مبدأ Contract.totalValue)
  statementValue Decimal           @db.Decimal(14, 2)
  status         StatementStatus   @default(DRAFT)
  issuedAt       DateTime?
  issuedById     String?
  issuedBy       User?             @relation("StatementIssuer", fields: [issuedById], references: [id], onDelete: SetNull)
  milestoneId    String?
  milestone      PaymentMilestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  notes          String?           @db.Text
  invoices       Invoice[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([documentNumber])
  @@index([contractId])
  @@index([status])
  @@map("progress_statements")
}

enum StatementStatus {
  DRAFT
  ISSUED
  PAID
}

// ── SCR-015 دفعة 1: كيان الفاتورة — schema فقط، المنطق والطباعة في الدفعة 2 ──
model Invoice {
  id             String             @id @default(cuid())
  documentNumber String?
  customerId     String
  customer       Customer           @relation(fields: [customerId], references: [id], onDelete: Restrict)
  contractId     String?
  contract       Contract?          @relation(fields: [contractId], references: [id], onDelete: Restrict)
  statementId    String?
  statement      ProgressStatement? @relation(fields: [statementId], references: [id], onDelete: SetNull)
  quotationId    String?
  quotation      Quotation?         @relation(fields: [quotationId], references: [id], onDelete: Restrict)
  subtotal       Decimal            @db.Decimal(14, 2)
  discountAmount Decimal            @default(0) @db.Decimal(14, 2)
  vatAmount      Decimal            @db.Decimal(14, 2)
  totalAmount    Decimal            @db.Decimal(14, 2)
  status         InvoiceStatus      @default(DRAFT)
  issuedAt       DateTime?
  issuedById     String?
  issuedBy       User?              @relation("InvoiceIssuer", fields: [issuedById], references: [id], onDelete: SetNull)
  notes          String?            @db.Text
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([documentNumber])
  @@index([customerId])
  @@index([contractId])
  @@index([status])
  @@map("invoices")
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  CANCELLED
}

model InspectionPhoto {
  id           String            @id @default(cuid())
  inspectionId String
  inspection   InspectionRequest @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  filename     String            @db.VarChar(300)
  originalName String            @db.VarChar(300)
  mimeType     String            @db.VarChar(100)
  sizeBytes    Int
  url          String            @db.VarChar(1000)
  caption      String?           @db.VarChar(500)
  takenAt      DateTime?
  uploadedById String
  uploadedBy   User              @relation("PhotoUploader", fields: [uploadedById], references: [id])
  createdAt    DateTime          @default(now())

  @@index([inspectionId])
  @@map("inspection_photos")
}

// ─────────────────────────────────────────────────────────────────────────────
// SCR-010 — Technical Office additions (applied 2026-07-07)
// ─────────────────────────────────────────────────────────────────────────────

model QuotationRequest {
  id                  String         @id @default(cuid())
  code                String         @unique @db.VarChar(50)
  status              TecJobStatus   @default(NEW)
  technicalRoute      TechnicalRoute @default(PROJECTS)
  summary             String?        @db.Text
  notes               String?        @db.Text
  customerId          String
  // دفعة هـ: nullable — الطلب يُنشأ أولًا (بلا عرض)، المكتب الفني يُنشئ العرض ويربطه (W-01)
  quotationId         String?        @unique
  inspectionRequestId String?        @unique
  engineerId          String?
  salesOwnerId        String?
  inspectionOwnerId   String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  deletedAt           DateTime?

  customer          Customer           @relation(fields: [customerId], references: [id], onDelete: Restrict)
  quotation         Quotation?         @relation(fields: [quotationId], references: [id], onDelete: Restrict)
  inspectionRequest InspectionRequest? @relation(fields: [inspectionRequestId], references: [id], onDelete: SetNull)
  engineer          User?              @relation("TecEngineer", fields: [engineerId], references: [id], onDelete: SetNull)
  salesOwner        User?              @relation("TecSalesOwner", fields: [salesOwnerId], references: [id], onDelete: SetNull)
  inspectionOwner   User?              @relation("TecInspectionOwner", fields: [inspectionOwnerId], references: [id], onDelete: SetNull)
  drawings          Drawing[]

  @@index([status])
  @@index([technicalRoute])
  @@index([status, technicalRoute])
  @@index([customerId])
  @@index([engineerId])
  @@index([inspectionRequestId])
  @@map("quotation_requests")
}

model Drawing {
  id                 String          @id @default(cuid())
  category           DrawingCategory
  fileType           DrawingFileType
  filename           String          @db.VarChar(300)
  originalName       String          @db.VarChar(300)
  mimeType           String          @db.VarChar(100)
  url                String          @db.VarChar(1000)
  sizeBytes          Int
  label              String?         @db.VarChar(200)
  notes              String?         @db.Text
  revision           String?         @db.VarChar(20)
  quotationRequestId String
  uploadedById       String
  approvedById       String?
  approvedAt         DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  // ── SCR-013: تتبّع بوابات الاعتماد (W-05 / R-01) ──
  status             DrawingStatus   @default(DRAFT)

  quotationRequest QuotationRequest @relation(fields: [quotationRequestId], references: [id], onDelete: Cascade)
  uploadedBy       User             @relation("DrawingUploader", fields: [uploadedById], references: [id], onDelete: Restrict)
  approvedBy       User?            @relation("DrawingApprover", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([quotationRequestId])
  @@index([quotationRequestId, category])
  @@index([approvedById])
  @@map("drawings")
}

enum DrawingStatus {
  DRAFT
  TEC_APPROVED
  INS_VERIFIED
  CEO_APPROVED
  RELEASED_TO_FACTORY
  REJECTED
}

model ExtraItem {
  id                   String        @id @default(cuid())
  type                 ExtraItemType
  description          String?       @db.VarChar(500)
  qty                  Decimal?      @db.Decimal(10, 2)
  unitCost             Decimal?      @db.Decimal(12, 2)
  notes                String?       @db.Text
  manufacturingOrderId String
  createdById          String
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  // ── SCR-013: INS يؤكد المقاسات (W-04) ──
  confirmedByInspection Boolean @default(false)

  manufacturingOrder ManufacturingOrder @relation(fields: [manufacturingOrderId], references: [id], onDelete: Restrict)
  createdBy          User               @relation("ExtraItemCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([manufacturingOrderId])
  @@index([type])
  @@map("extra_items")
}

enum TecJobStatus {
  NEW
  IN_PROGRESS
  ON_HOLD
  DONE
}

enum TechnicalRoute {
  PROJECTS
  SOCIAL_MEDIA
}

enum DrawingCategory {
  DRAWINGS
  STRUCTURAL_CALC
  DATA_SHEET
  EXECUTION_DRAWINGS
  APPROVALS
}

enum DrawingFileType {
  PDF
  DWG
  JPG
}

enum ExtraItemType {
  CHAMFER
  WELDING
  EXTRA_ACCESSORY
  OUT_OF_CAIRO_TRANSPORT
  SANDING
}
