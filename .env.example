# Copy this file to `.env` and fill values. NEVER commit the real `.env`.
# For local Docker dev, the values below already match docker-compose.yml.

# Database connection (inside Docker, host is the service name "db")
DATABASE_URL="postgresql://egyglass:egyglass_dev_pw@db:5432/egyglass?schema=public"

# Auth.js secret — generate a real random value for production:
#   openssl rand -base64 32
AUTH_SECRET="dev-secret-change-me"

# App URL (host port 3100 → container 3000, set in docker-compose.yml)
NEXTAUTH_URL="http://localhost:3100"
